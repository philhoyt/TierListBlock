{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tier-list/tier-content",
	"version": "1.0.0",
	"title": "Tier Content",
	"category": "design",
	"description": "The content zone for a tier row.",
	"icon": "images-alt2",
	"textdomain": "tier-list-block",
	"parent": [ "tier-list/tier-item" ],
	"attributes": {
		"style": {
			"type": "object",
			"default": {
				"color": {
					"text": "#ffffff"
				}
			}
		}
	},
	"supports": {
		"html": false,
		"inserter": false,
		"color": {
			"text": true,
			"background": false,
			"__experimentalDefaultControls": {
				"text": true
			}
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
