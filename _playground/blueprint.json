{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Tier List Block",
		"description": "TierMaker-style tier list block for the WordPress block editor.",
		"author": "Phil Hoyt",
		"categories": [ "blocks", "content" ]
	},
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"login": true,
	"landingPage": "/wp-admin/edit.php",
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "url",
				"url": "https://github.com/philhoyt/TierListBlock/releases/latest/download/tier-list-block.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Tier List Block Demo"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/philhoyt/TierListBlock/main/_playground/demo.xml"
			}
		}
	]
}
